# URL del Google Apps Script desplegado
REACT_APP_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/TU_ID_AQUI/exec

# API key compartida (la misma que en Script Properties)
REACT_APP_API_KEY=tu-api-key-aqui

# Site key de Cloudflare Turnstile (la pública, NO el secret)
REACT_APP_TURNSTILE_SITE_KEY=0x4AAAAAAA...
