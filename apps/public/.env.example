# ============================================================================
# CONFIGURACIÓN APP PÚBLICA — Formulario de denuncias
# ============================================================================
# Instrucciones: Ver GUIA_COMPLETA_SETUP.md en la raíz del proyecto
# ============================================================================

# URL del Google Apps Script desplegado como Web App
# Obtenerla en: Google Apps Script → Implementar → Nueva implementación → Copiar URL
# Formato: https://script.google.com/macros/s/[SCRIPT_ID]/exec
REACT_APP_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/TU_SCRIPT_ID_AQUI/exec

# API Key de acceso (debe coincidir con Script Properties → TURNSTILE_SECRET)
# Usar una contraseña fuerte (mín 32 caracteres)
REACT_APP_API_KEY=tu_api_key_fuerte_aqui

# Site Key de Cloudflare Turnstile (KEY PÚBLICA, no el secret)
# Obtenerla en: https://dash.cloudflare.com/turnstile → Tu sitio
# Ejemplo: 0x4AAAAAADz_9q1P61sGjB7C
REACT_APP_TURNSTILE_SITE_KEY=0x4AAAAAAA_tu_site_key_aqui
